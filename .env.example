# Progressive Agent — Environment Variables
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# === Claude (через подписку Max — основной способ) ===
# URL локального прокси для Claude Max подписки
# Установи CLIProxyAPI: https://github.com/anthropics/CLIProxyAPI
# По умолчанию: http://127.0.0.1:8317/v1
CLAUDE_PROXY_URL=http://127.0.0.1:8317/v1

# === Claude API (fallback, если прокси недоступен) ===
# Anthropic API key — НЕ обязательный, только как запасной вариант
# ANTHROPIC_API_KEY=sk-ant-xxx

# === Mistral AI (бесплатный fallback — 1B tokens/month) ===
# Mistral API key — FREE TIER! Получи на console.mistral.ai
# Используется как fallback когда комп выключен (Claude proxy недоступен)
MISTRAL_API_KEY=

# === Telegram ===
# Bot token от @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# === Поиск (все 4 провайдера) ===
# Tavily (https://tavily.com/) — основной поисковик
TAVILY_API_KEY=tvly-xxx
# Multiple Tavily keys for auto-rotation (comma-separated)
# When credits run out on one key, bot auto-switches to next
TAVILY_API_KEYS=tvly-key1,tvly-key2,tvly-key3

# SerpApi (https://serpapi.com/) — Google поисковая выдача
SERPAPI_API_KEY=

# Jina (https://jina.ai/) — Reader API + Search API
JINA_API_KEY=

# Firecrawl (https://firecrawl.dev/) — веб-скрапинг
FIRECRAWL_API_KEY=

# === Twitch (https://dev.twitch.tv/console) ===
# Зарегистрируй приложение на dev.twitch.tv, получи Client ID и Secret
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# === YouTube Data API v3 (https://console.cloud.google.com/) ===
# Включи YouTube Data API v3 в Google Cloud Console, создай API Key
YOUTUBE_API_KEY=

# === Monobank (https://api.monobank.ua/) ===
# Перейди на api.monobank.ua, авторизуйся через приложение, получи токен
MONOBANK_API_TOKEN=

# === OpenAI (для embeddings и Whisper STT) ===
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx

# === DeepL (https://www.deepl.com/pro-api) ===
# Free tier: 500,000 chars/month
DEEPL_API_KEY=

# === Finnhub (https://finnhub.io/) ===
# Free tier: 60 API calls/min, real-time stocks/crypto/forex
FINNHUB_API_KEY=

# === Nova Poshta (https://developers.novaposhta.ua/) ===
# API v2.0, free, no rate limits. Get key: new.novaposhta.ua → Настройки → Безпека → API ключ
NOVAPOSHTA_API_KEY=

# === Google Gemini (https://aistudio.google.com/apikey) ===
# Free tier: 15 RPM, 1500 RPD. Multimodal (vision + text)
# Добавляется в цепочку fallback провайдеров (бесплатный!)
GEMINI_API_KEY=

# === Cloudflare Workers AI (https://dash.cloudflare.com/) ===
# Free tier: 10,000 neurons/day. 50+ моделей (LLM, image, speech)
# Settings → Account → Account ID + API Tokens → Create Token
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# === Alerts.in.ua (https://alerts.in.ua/) ===
# Повітряні тривоги по Україні в реальному часі
# Зареєструйся на alerts.in.ua для отримання API токена
ALERTS_UA_TOKEN=

# === TMDB (https://www.themoviedb.org/settings/api) ===
# Фільми, серіали, рейтинги, рекомендації. Безкоштовний ключ
TMDB_API_KEY=

# === Telegram whitelist (user IDs через запятую) ===
# Если пустой — бот доступен всем (dev mode)
ALLOWED_USERS=
